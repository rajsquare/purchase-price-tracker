# Copy this file to .env.local and fill in your Firebase project's web app config
# (Firebase Console -> Project settings -> General -> Your apps -> SDK setup and configuration).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Price List project (pricelist-a9d70) — the read-only, authoritative product
# catalog. Purchase Tracker never writes here.
VITE_PRICELIST_FIREBASE_API_KEY=
VITE_PRICELIST_FIREBASE_AUTH_DOMAIN=
VITE_PRICELIST_FIREBASE_PROJECT_ID=pricelist-a9d70
VITE_PRICELIST_FIREBASE_STORAGE_BUCKET=
VITE_PRICELIST_FIREBASE_MESSAGING_SENDER_ID=
VITE_PRICELIST_FIREBASE_APP_ID=
